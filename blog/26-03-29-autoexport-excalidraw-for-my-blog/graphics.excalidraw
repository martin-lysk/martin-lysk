      ],
      "updated": 1774833133564,
      "link": null,
      "locked": false,
      "text": "I use an excalidraw extension to draw the frames, \nit automatically generates svg's for all frames\nwith `export_` prefix.\n\nThis allows me to reference the \"frames\" as normal\nimages:\n\n![export](./export.dark.exp.svg#gh-dark-mode-only)\n![export](./export.light.exp.svg#gh-light-mode-only)",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "I use an excalidraw extension to draw the frames, \nit automatically generates svg's for all frames\nwith `export_` prefix.\n\nThis allows me to reference the \"frames\" as normal\nimages:\n\n![export](./export.dark.exp.svg#gh-dark-mode-only)\n![export](./export.light.exp.svg#gh-light-mode-only)",
      "autoResize": true,
      "lineHeight": 1.25
    },
